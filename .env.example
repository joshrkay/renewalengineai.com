# Database
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (Resend)
RESEND_API_KEY="re_..."
FROM_EMAIL="RenewalEngineAI <noreply@renewalengineai.com>"

# n8n Cloud
N8N_BASE_URL="https://your-instance.app.n8n.cloud"
N8N_API_KEY="your-n8n-api-key"

# LangGraph
LANGGRAPH_API_URL="https://your-langgraph-service.com"
LANGGRAPH_API_KEY="your-langgraph-api-key"

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY="your-64-char-hex-key"

# Webhook HMAC Secret (for n8n/LangGraph callback verification)
WEBHOOK_SECRET="your-webhook-hmac-secret"

# Vercel Cron Secret
CRON_SECRET="your-cron-secret"

# OAuth Providers (for customer integrations)
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
OUTLOOK_CLIENT_ID=""
OUTLOOK_CLIENT_SECRET=""
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
